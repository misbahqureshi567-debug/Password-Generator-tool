import random
import string

def generate_password(length):
    # Define the possible characters
    letters = string.ascii_letters
    digits = string.digits
    special_chars = string.punctuation
    
    # Combine all characters
    all_characters = letters + digits + special_chars
    
    # Use SystemRandom for better security than the standard random.choice
    secure_random = random.SystemRandom()
    
    # Generate the password
    password = ''.join(secure_random.choice(all_characters) for _ in range(length))
    
    return password

def main():
    print("--- Secure Password Generator ---")
    
    try:
        # User input for length
        user_length = int(input("Enter the desired password length: "))
        
        if user_length < 8:
            print("Warning: Passwords shorter than 8 characters are less secure.")
        
        # Generate and display
        new_password = generate_password(user_length)
        print(f"\nYour generated password is: {new_password}")
        print("-" * 33)
        
    except ValueError:
        print("Invalid input! Please enter a whole number for the length.")

if __name__ == "__main__":
    main()


 